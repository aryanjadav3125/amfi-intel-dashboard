# Application Settings
LOG_LEVEL=INFO

# Database Connection (Postgres default, SQLite as fallback if configured)
# For Local Postgres: postgresql+asyncpg://postgres:postgres@localhost:5432/amfi
# For Local SQLite fallback: sqlite+aiosqlite:///./amfi.db
DATABASE_URL=sqlite+aiosqlite:///./amfi.db

# AMFI Data Configuration
AMFI_NAV_URL=https://www.amfiindia.com/spages/NAVAll.txt
SCRAPER_TIMEOUT=30
SCRAPER_RETRY_COUNT=3
SCRAPER_RETRY_DELAY=5

# Scheduler Configuration (Cron format - standard is 23:00 IST / 17:30 UTC)
SCHEDULER_CRON_HOUR=23
SCHEDULER_CRON_MINUTE=00

# Notifications Setup
# Options: console, slack, telegram, email
NOTIFICATION_CHANNEL=console

# SMTP Settings (For Email Notifier)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_TO=receiver_email@gmail.com

# Slack Settings (For Slack Notifier)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Telegram Settings (For Telegram Notifier)
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQRsTUVwxyZ
TELEGRAM_CHAT_ID=-100123456789
